[node name="Note_01" type="StaticBody3D" parent="Notes"]
position = Vector3(-3.5, 0.85, 8.0)
script = ExtResource("3")
note_id = "reception_note"
note_title = "Направление — Доктор Волков"
note_content = "Дата: 14 ноября 1994
Пациент: Алексей Д., 34 года
Диагноз: Параноидная шизофрения с галлюцинациями

Пациент настаивает, что видит 'тёмные фигуры' в коридорах. Утверждает, что слышит шёпот в стенах. Назначено усиленное медикаментозное лечение.

Примечание: странные царапины на стенах палаты №7. Пациент не может объяснить их происхождение."
interact_text = "Прочитать направление"

[node name="CollisionShape3D" type="CollisionShape3D" parent="Notes/Note_01"]
shape = SubResource("note_col")
[node name="Mesh" type="MeshInstance3D" parent="Notes/Note_01"]
