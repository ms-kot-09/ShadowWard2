[node name="Note_03" type="StaticBody3D" parent="Notes"]
position = Vector3(-5.0, 0.85, 24.0)
script = ExtResource("3")
note_id = "warning_note"
note_title = "Предупреждение (нацарапано на стене)"
note_content = "ОНО ВИДИТ ТЕБЯ КОГДА ТЫ ЕГО НЕ ВИДИШЬ

не смотри в зеркала
держи свет включённым
не ходи один в подвал

я пытался убежать
оно всегда возвращается
ОНО ВСЕГДА ВОЗВРАЩАЕТСЯ"
interact_text = "Рассмотреть надпись"

