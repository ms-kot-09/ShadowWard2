surface_material_override/0 = SubResource("note_mat")

[node name="Note_02" type="StaticBody3D" parent="Notes"]
position = Vector3(10.0, 0.85, 7.0)
rotation = Vector3(0, 0.5, 0)
script = ExtResource("3")
note_id = "office_diary"
note_title = "Личный дневник — Доктор Волков"
note_content = "12 декабря.
Три недели без нормального сна. Пациенты успокоились после увеличения дозы, но я... я сам начинаю видеть вещи.

Вчера ночью в коридоре стояла фигура. Когда я включил свет — никого.

Может, это переутомление. Но почему все камеры в крыле А перестали работать одновременно?

Нужно выбраться отсюда."
interact_text = "Прочитать дневник"

[node name="CollisionShape3D" type="CollisionShape3D" parent="Notes/Note_02"]
shape = SubResource("note_col")
[node name="Mesh" type="MeshInstance3D" parent="Notes/Note_02"]
